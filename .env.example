# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://evaladmin:evalpass123@localhost:27017/eval_pipeline?authSource=admin
MONGO_DB_NAME=eval_pipeline

# ── Kafka ─────────────────────────────────────────────────────────────────────
