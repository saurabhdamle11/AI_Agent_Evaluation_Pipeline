# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false

# ── MongoDB ───────────────────────────────────────────────────────────────────
# When running outside Docker use localhost:27017
# When running inside Docker the service name resolves: mongodb:27017
MONGO_URI=mongodb://<user>:<password>@localhost:27017/eval_pipeline?authSource=admin
MONGO_DB_NAME=eval_pipeline
MONGO_USER=evaladmin
MONGO_PASSWORD=changeme

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Outside Docker → localhost:9094 (external listener)
# Inside Docker  → kafka:9092    (internal listener, set automatically by docker-compose)
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_TOPIC_CONVERSATIONS=conversations.raw
KAFKA_TOPIC_FEEDBACK=feedback.raw
KAFKA_TOPIC_EVALUATIONS=evaluations.trigger
KAFKA_CONSUMER_GROUP=eval-pipeline-consumers
